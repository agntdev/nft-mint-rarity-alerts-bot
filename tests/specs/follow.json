[
  {
    "name": "/follow",
    "steps": [
      {
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Send contract address, keyword or creator handle (e.g. 0x123... or azuki or @creator)."
            }
          }
        ],
        "send": {
          "text": "/follow"
        }
      }
    ]
  },
  {
    "name": "follow by keyword via button and input",
    "steps": [
      { "send": { "text": "/start" }, "expect": [{ "method": "sendMessage" }] },
      { "send": { "callback": "follow:start" }, "expect": [{ "method": "sendMessage" }] },
      { "send": { "text": "azuki" }, "expect": [{ "method": "sendMessage", "payload": { "text": "Subscribed to azuki.\nAlerts enabled for all types." } }] }
    ]
  }
]
