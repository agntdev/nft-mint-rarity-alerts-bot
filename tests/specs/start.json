[
  {
    "name": "/start replies with the welcome + main menu",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "NFT alerts for verified projects.\nEthereum • Solana • Base.\nAuto-follow trending: on." }
          }
        ]
      }
    ]
  },
  {
    "name": "end-to-end onboarding flow",
    "steps": [
      { "send": { "text": "/start" }, "expect": [ { "method": "sendMessage" } ] },
      { "send": { "callback": "prefs:toggle_auto" }, "expect": [ { "method": "editMessageText" } ] },
      { "send": { "callback": "follow:start" }, "expect": [ { "method": "sendMessage" } ] }
    ]
  }
]
